model AdminActionLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  payloadJson Json    @map("payload_json")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("admin_action_logs")
}

enum InactivityReminderTemplateCategory {
  SOFT
  MOTIVATING
  BUSINESS
  LIGHT_HUMOR
  HOOKING
  CALL_TO_ACTION
}

enum InactivityReminderCtaTargetType {
  ROOT
  NEXT_PAGE
}

enum InactivityReminderStateStatus {
  PENDING
  CANCELLED
  SENT
  EXPIRED
}

model ReminderTemplate {
  id              String                          @id @default(uuid())
  key             String                          @unique
  category       InactivityReminderTemplateCategory
  title          String
  text           String
  defaultCtaLabel String                          @map("default_cta_label")
  isActive       Boolean                         @default(true) @map("is_active")
  sortOrder      Int                             @default(0) @map("sort_order")
  languageCode   String                          @default("ru") @map("language_code")
  createdAt      DateTime                        @default(now()) @map("created_at")
  updatedAt      DateTime                        @updatedAt @map("updated_at")

  rules           InactivityReminderRule[]

  @@index([isActive, languageCode, category, sortOrder])
  @@map("reminder_templates")
}

model InactivityReminderRule {
  id             String                              @id @default(uuid())
  templateId     String                              @map("template_id")
  template       ReminderTemplate                   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  triggerPageId  String                              @map("trigger_page_id")
  targetMenuItemId String                           @map("target_menu_item_id")
  delayMinutes   Int                                @map("delay_minutes")
  ctaLabel       String                              @map("cta_label")
  ctaTargetType  InactivityReminderCtaTargetType     @map("cta_target_type")
  isActive       Boolean                            @default(true) @map("is_active")

  createdAt      DateTime                           @default(now()) @map("created_at")
  updatedAt      DateTime                           @updatedAt @map("updated_at")

  states         UserInactivityReminderState[]

  @@index([triggerPageId])
  @@index([isActive])
  @@map("inactivity_reminder_rules")
}

model UserInactivityReminderState {
  id               String                          @id @default(uuid())
  userId           String                          @map("user_id")
  ruleId           String                          @map("rule_id")

  rule             InactivityReminderRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user             User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  triggerPageId   String                          @map("trigger_page_id")
  targetMenuItemId String                          @map("target_menu_item_id")

  status           InactivityReminderStateStatus  @default(PENDING)
  scheduledFor     DateTime                      @map("scheduled_for")
  sentAt           DateTime?                     @map("sent_at")
  cancelledAt      DateTime?                     @map("cancelled_at")
  schedulerJobId   String?                      @map("scheduler_job_id")

  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")

  @@unique([userId, ruleId])
  @@index([status, scheduledFor])
  @@map("user_inactivity_reminder_states")
}
