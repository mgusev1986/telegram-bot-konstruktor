# Optional when running multi-bot from DB (bots created via back-office).
# Required for initial setup or when no active bots exist in DB.
BOT_TOKEN=
BOT_USERNAME=

# Required for encrypting bot tokens stored in DB. Must match the key used when bots were created.
BOT_TOKEN_ENCRYPTION_KEY=dev-insecure-change-me

# DATABASE_URL — host depends on where the app runs:
# - Docker (bot container): use postgres (hostname inside docker network)
# - Local dev (npm run dev, prisma migrate dev from host): use localhost
#   Example: postgresql://postgres:postgres@localhost:5432/telegram_bot_konstruktor?schema=public
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/telegram_bot_konstruktor?schema=public
# REDIS_URL — same logic: redis for Docker, localhost:6379 for local dev
REDIS_URL=redis://redis:6379
SUPER_ADMIN_TELEGRAM_ID=
DEFAULT_LANGUAGE=ru
# New users must open the bot via ?start=<telegramUserId> (false = allow direct /start for anyone).
REQUIRE_REFERRAL_LINK_FOR_NEW_USERS=true
APP_TIMEZONE=UTC
PAYMENT_PROVIDER_MODE=crypto
USDT_TRC20_WALLET=
USDT_BEP20_WALLET=

# NOWPayments (balance-based flow). When set, paywall uses internal balance.
# NOWPAYMENTS_IPN_CALLBACK_URL must be full URL, e.g. https://yourdomain.com/webhooks/payments/nowpayments
# If your admin hostname is behind Cloudflare Access, exclude /webhooks/payments/nowpayments*
# from Access or use a dedicated public webhook hostname.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_IPN_CALLBACK_URL=
# NOWPayments v1 (payouts, defaults). Optional.
# NOWPAYMENTS_USE_CUSTODY=false
# NOWPAYMENTS_DEFAULT_PAY_CURRENCY=usdtbsc
# NOWPAYMENTS_DEFAULT_SETTLEMENT_CURRENCY=usdttrc20
# NOWPAYMENTS_PAYOUT_FEE_POLICY=deduct_from_payout
# NOWPAYMENTS_DAILY_PAYOUT_CRON=
# NOWPAYMENTS_DAILY_PAYOUT_TIMEZONE=Europe/Madrid
# For Mass Payouts API (owner daily payouts). Required for payouts.
# NOWPAYMENTS_EMAIL=
# NOWPAYMENTS_PASSWORD=
# Secret for cron-triggered payout: POST /webhooks/payments/owner-payout-trigger?secret=xxx
# NOWPAYMENTS_PAYOUT_TRIGGER_SECRET=
HTTP_PORT=3000
LOG_LEVEL=info

# Back-office (web admin)
BACKOFFICE_JWT_SECRET=dev-backoffice-secret-change-me
BACKOFFICE_COOKIE_NAME=backoffice_session
BACKOFFICE_ADMIN_EMAIL=
BACKOFFICE_ADMIN_PASSWORD=
# Email of backoffice user with platform-wide ALPHA_OWNER access (global user directory). Optional.
# BACKOFFICE_ALPHA_EMAIL=

# Translation provider (one-time admin action; no per-user runtime calls):
# - ollama: local only
# - cerebras: online only
# - auto: try ollama first, fallback to cerebras if ollama fails during translation
TRANSLATION_PROVIDER=ollama

# Ollama (used when TRANSLATION_PROVIDER=ollama or in auto mode)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Cerebras (used when TRANSLATION_PROVIDER=cerebras or in auto mode)
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Optional: if primary is ollama/cerebras, wrap with an additional fallback provider on provider errors.
# TRANSLATION_FALLBACK_PROVIDER=cerebras

TRANSLATION_TIMEOUT_MS=30000
TRANSLATION_BATCH_SIZE=1
TRANSLATION_OVERWRITE_DEFAULT=true

# Legacy AI_* variables are still supported, but prefer TRANSLATION_* for new deployments.
# AI_TRANSLATION_PROVIDER=ollama
# AI_TRANSLATION_MODEL=qwen2.5:14b

# Legacy workers_ai (Cloudflare) support (not required for Cerebras integration)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_API_TOKEN=
# CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
