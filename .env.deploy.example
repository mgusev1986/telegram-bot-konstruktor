# Конфигурация деплоя на Hetzner (scripts/deploy-hetzner.sh)
# Скопируйте в .env.deploy и заполните значения.
# .env.deploy не коммитится в git.

# IP или hostname сервера
HETZNER_HOST=77.42.79.54

# SSH-пользователь
HETZNER_USER=root

# Директория приложения на сервере
HETZNER_APP_DIR=/opt/telegram-bot-konstruktor

# Пароль для SSH (нужен только если нет SSH-ключа)
# Для работы без ввода пароля лучше настроить ключ: ssh-copy-id root@77.42.79.54
HETZNER_SSH_PASSWORD=GMOcbvf7021986mg888!!!
