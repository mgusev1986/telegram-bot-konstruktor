{
  "name": "telegram-bot-konstruktor",
  "version": "0.1.0",
  "private": true,
  "description": "Production-like Telegram constructor for MLM presentation bots",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "prisma migrate deploy && node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot_konstruktor?schema=public prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:dev:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot_konstruktor?schema=public prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed-demo": "tsx prisma/seed-demo-structure.ts",
    "deploy": "bash scripts/deploy-hetzner.sh",
    "lint:types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@prisma/client": "^6.5.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.47.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.1",
    "telegraf": "^4.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
