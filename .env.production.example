# Production (Hetzner VPS)
# Скопируйте в .env и заполните значения
#
# HTTPS через Cloudflare Tunnel: см. docs/CLOUDFLARE_TUNNEL.md

POSTGRES_PASSWORD=придумайте_надёжный_пароль_32_символа

BOT_TOKEN=токен_от_BotFather
BOT_USERNAME=@ваш_бот
BOT_TOKEN_ENCRYPTION_KEY=придумайте_ключ_32_символа
SUPER_ADMIN_TELEGRAM_ID=ваш_telegram_id

DATABASE_URL=postgresql://postgres:ПАРОЛЬ_ИЗ_POSTGRES_PASSWORD@postgres:5432/telegram_bot_konstruktor?schema=public
REDIS_URL=redis://redis:6379

BACKOFFICE_JWT_SECRET=придумайте_секрет_32_символа
BACKOFFICE_ADMIN_EMAIL=admin@example.com
BACKOFFICE_ADMIN_PASSWORD=надёжный_пароль_6_символов

TRANSLATION_PROVIDER=cerebras
CEREBRAS_API_KEY=ваш_ключ_cerebras

DEFAULT_LANGUAGE=ru
APP_TIMEZONE=Europe/Warsaw
NODE_ENV=production
LOG_LEVEL=info
HTTP_PORT=3000

# NOWPayments — после настройки Cloudflare Tunnel подставьте ваш HTTPS-домен
# Если admin.MY_DOMAIN.com защищён Cloudflare Access, добавьте Bypass policy/app
# для пути /webhooks/payments/nowpayments* (см. docs/CLOUDFLARE_TUNNEL.md).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_IPN_CALLBACK_URL=https://admin.MY_DOMAIN.com/webhooks/payments/nowpayments
