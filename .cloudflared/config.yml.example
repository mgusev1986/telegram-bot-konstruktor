# Cloudflare Tunnel — пример конфигурации (Hetzner + backoffice)
#
# Вариант A: Через Dashboard (рекомендуется)
#   1. Zero Trust → Tunnels → Create tunnel → Cloudflared
#   2. Имя: telegram-bot-konstruktor
#   3. Add public hostname: admin.MY_DOMAIN.com → http://localhost:3000
#   4. Используйте tunnel token с systemd (см. docs/CLOUDFLARE_TUNNEL.md)
#
# Вариант B: Локальный config (если не используете token)
#   cloudflared tunnel login
#   cloudflared tunnel create telegram-bot-konstruktor
#   cloudflared tunnel route dns telegram-bot-konstruktor admin.MY_DOMAIN.com
#   cloudflared tunnel run telegram-bot-konstruktor

tunnel: <TUNNEL_UUID>
credentials-file: /root/.cloudflared/<TUNNEL_UUID>.json

ingress:
  - hostname: admin.MY_DOMAIN.com
    service: http://localhost:3000
  - service: http_status:404
